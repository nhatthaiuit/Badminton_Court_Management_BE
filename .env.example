# ==============================
# SERVER CONFIGURATION
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# DATABASE CONFIGURATION (MySQL)
# ==============================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=bcms_db

# ==============================
# JWT AUTHENTICATION
# ==============================
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ==============================
# CORS - Allowed Frontend Origin
# ==============================
CORS_ORIGIN=http://localhost:5173
